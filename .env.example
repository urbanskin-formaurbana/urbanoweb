# Frontend Environment Variables
VITE_REPO_URL=https://github.com/urbanskin-formaurbana/urbanoweb

# Backend API Configuration
# Production: https://urbanoweb-backend.onrender.com/api/v1
# Local Development (HTTPS): https://localhost:8443/api/v1
# Local Development (HTTP): http://localhost:8000/api/v1
VITE_API_URL=https://localhost:8443/api/v1

# Google OAuth Configuration
# Get from: https://console.cloud.google.com/
# Create OAuth 2.0 credentials (Web application) and add authorized origins
VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# MercadoPago Configuration
# Get from: https://www.mercadopago.com.uy/developers/panel/app
# Use TEST- prefix for test environment, APP_USR- for production
VITE_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key_here
