# Frontend Environment Variables
VITE_REPO_URL=https://github.com/urbanskin-formaurbana/urbanoweb

# Backend API Configuration
# Production: https://api.formaurbana.skin/api/v1
# Local Development (HTTPS): https://localhost:8443/api/v1
# Local Development (HTTP): http://localhost:8000/api/v1
VITE_API_URL=https://localhost:8443/api/v1

# Google OAuth Configuration
# Get from: https://console.cloud.google.com/
# Create OAuth 2.0 credentials (Web application) and add authorized origins
VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com

# MercadoPago Configuration
# Get from: https://www.mercadopago.com.uy/developers/panel/app
# Use TEST- prefix for test environment, APP_USR- for production
VITE_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key_here

# SuperTokens (local dev: docker-compose runs its own SuperTokens + Postgres;
# prod uses the Coolify-hosted instance with its own values)
SUPERTOKENS_POSTGRES_PASSWORD=supertokens_local_dev
SUPERTOKENS_API_KEY=local_dev_api_key_change_me

# SuperTokens frontend config
# apiDomain: base URL of the backend (without /api/v1 — SuperTokens uses /auth)
# websiteDomain: base URL of the frontend
VITE_SUPERTOKENS_API_DOMAIN=https://localhost:8443
VITE_SUPERTOKENS_WEBSITE_DOMAIN=https://localhost:5173

# Google OAuth (used by SuperTokens ThirdParty recipe on the backend)
# Same OAuth client as today; ensure both
#   https://localhost:5173/auth/callback/google
#   https://formaurbana.skin/auth/callback/google
# are registered as authorized redirect URIs in Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
